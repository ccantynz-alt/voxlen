# Voxlen billing service — required environment variables.
#
# Copy to .env for local dev; set these in your hosting provider's
# secret manager for production.

# Stripe (Dashboard → Developers → API keys / Webhooks)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Ed25519 private key seed (32-byte hex). Generate once with:
#   npm run keygen
# Embed the matching public key into the desktop build via
# VOXLEN_LICENSE_PUBKEY at `cargo tauri build` time.
VOXLEN_LICENSE_PRIVKEY=

# Transactional email (resend.com). Swap for Postmark/SES with small
# edits in server.ts if you prefer another provider.
RESEND_API_KEY=re_...
RESEND_FROM=Voxlen <licenses@voxlen.ai>

# Stripe Price IDs for each tier. Create Products + Prices in the
# Stripe Dashboard, then paste the resulting price_... IDs here.
PRICE_ID_PRO=price_...
PRICE_ID_PROFESSIONAL=price_...
PRICE_ID_LIFETIME=price_...

# HTTP listen port (most serverless hosts set this automatically)
PORT=8080
