# Voxlen environment variables (developer-side only).
#
# The product itself stores user API keys on-device via the Settings UI —
# NEVER commit real keys or put user keys in a .env. These variables are
# strictly for local development, CI, and build tooling.

# ---------- Tauri dev server ----------
# Host the Vite dev server should listen on when tauri dev is launched from
# another device (phone, VM). Leave empty for the default localhost-only bind.
TAURI_DEV_HOST=

# ---------- Landing page / SDK smoke tests (optional) ----------
# Used only by the SDK demo in sdk/examples for local smoke testing.
# Leave blank in real deployments; the Voxlen app uses user-provided keys.
VITE_VOXLEN_DEEPGRAM_KEY=
VITE_VOXLEN_ANTHROPIC_KEY=
VITE_VOXLEN_OPENAI_KEY=

# ---------- GitHub release integration ----------
# Optional PAT used by release scripts to look up the latest notarized build.
# A classic PAT with public_repo scope is sufficient.
GH_RELEASES_TOKEN=

# ---------- Analytics / telemetry ----------
# If set, enables anonymous crash telemetry on the landing page. Users can
# still opt out at runtime. Leave blank to disable entirely.
VITE_TELEMETRY_ENDPOINT=
